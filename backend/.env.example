SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Neon) ---
# From the Neon dashboard connection string:
#   postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
# Use the host WITHOUT the "-pooler" suffix for migrations.
DB_NAME=giftgraph
DB_USER=giftgraph_user
DB_PASSWORD=giftgraph_pass
DB_HOST=
DB_PORT=5432
DB_CONN_MAX_AGE=0

GEMINI_API_KEY=your-gemini-api-key-here

# --- Redis / Celery (Upstash) ---
# Upstash uses TLS — note the rediss:// scheme (double s):
#   rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
